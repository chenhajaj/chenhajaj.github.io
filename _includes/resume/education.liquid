{% assign education = data %}
<div class="timeline">
  {% for item in education %}
    <div class="timeline-item">
      <div class="timeline-card">
        <div class="timeline-year">{{ item.endDate }}</div>
        <h4 class="timeline-title">
          {{ item.studyType -}}
          {%- if item.area %} in {{ item.area }}{% endif %}
        </h4>
        <div class="timeline-institution">{{ item.institution }}</div>

        {% if item.thesis %}
          <div class="cv-detail">
            <i class="fas fa-book cv-detail-icon"></i>
            <div>
              <div class="cv-detail-label">Thesis:</div>
              <div class="cv-detail-value">{{ item.thesis }}</div>
            </div>
          </div>
        {% endif %}

        {% if item.host or item.advisor %}
          <div class="cv-detail" style="margin-top: 0.75rem;">
            <i class="fas fa-user-tie cv-detail-icon"></i>
            <div>
              <div class="cv-detail-label">
                {% if item.host %}Host{% else %}Advisor{% endif %}:
              </div>
              <div class="cv-detail-value">
                {{ item.host -}}
                {{- item.advisor }}
              </div>
            </div>
          </div>
        {% endif %}
      </div>
    </div>
  {% endfor %}
</div>

<style>
  .education {
    margin-bottom: 1.5rem;
  }

  .education-item {
    margin-bottom: 2rem;
    padding: 1rem 1rem 1rem 1.25rem;
    border-left: 3px solid #e2e8f0;
    background: #f8fafc;
    border-radius: 0 8px 8px 0;
    transition: all 0.3s ease;
  }

  .education-item:last-child {
    margin-bottom: 0;
  }

  .education-item:hover {
    border-left-color: var(--global-theme-color);
    background-color: #ffffff;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
    transform: translateX(4px);
  }

  .entry-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 0.4rem;
  }

  .main-info {
    flex: 1;
  }

  .degree {
    color: #1a202c;
    font-weight: 600;
    font-size: 1.1rem;
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
    margin: 0 0 0.3rem 0;
    letter-spacing: -0.01em;
  }

  .institution {
    color: #4a5568;
    font-size: 0.95rem;
    font-weight: 500;
    margin-bottom: 0.2rem;
  }

  .period {
    color: #718096;
    font-size: 0.9rem;
    font-weight: 500;
    white-space: nowrap;
    margin-left: 1rem;
  }

  .entry-details {
    margin-top: 0.75rem;
    padding-top: 0.75rem;
    border-top: 1px solid #e2e8f0;
  }

  .detail-line {
    display: flex;
    align-items: baseline;
    color: #4a5568;
    font-size: 0.8rem;
    margin-bottom: 0.3rem;
    line-height: 1.5;
  }

  .detail-line.thesis {
    font-size: 0.75rem;
  }

  .detail-line.thesis .content {
    font-size: 0.75rem;
  }

  .detail-line i {
    color: #4b6cb7;
    width: 1rem;
    margin-right: 0.5rem;
    font-size: 0.85rem;
    text-align: center;
  }

  .label {
    font-weight: 600;
    margin-right: 0.4rem;
    color: #4a5568;
  }

  .content {
    color: #2d3748;
  }

  .thesis em {
    font-style: italic;
  }

  @media (max-width: 768px) {
    .entry-header {
      flex-direction: column;
    }

    .period {
      margin: 0.2rem 0 0 0;
    }

    .detail-line {
      padding-right: 0.5rem;
    }
  }
</style>
