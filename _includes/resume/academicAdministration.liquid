{% assign positions = data %}
<div class="timeline">
  {% for item in positions %}
    <div class="timeline-item">
      <div class="timeline-card">
        <div class="timeline-year">{{ item.startDate }} - {{ item.endDate }}</div>
        <h4 class="timeline-title">{{ item.position | capitalize }}</h4>
        <div class="timeline-institution">{{ item.institution }}</div>
      </div>
    </div>
  {% endfor %}
</div>

<style>
  .positions {
    margin-bottom: 1.5rem;
  }
  .position-item {
    margin-bottom: 1.5rem;
    padding-left: 1rem;
    border-left: 3px solid transparent;
  }
  .position-item:hover {
    border-left-color: #2a6496;
  }
  .position-title {
    color: #2a6496;
    font-weight: 600;
    margin-bottom: 0.25rem;
  }
  .institution {
    font-weight: 500;
    color: #495057;
    margin-bottom: 0.25rem;
  }
  .period {
    color: #6c757d;
  }
  .period i {
    margin-right: 0.5rem;
  }
</style>
