{% assign patents = data %}
<div class="timeline">
  {% for item in patents %}
    <div class="timeline-item">
      <div class="timeline-card">
        <div class="timeline-year">{{ item.year }}</div>
        <h4 class="timeline-title">{{ item.title }}</h4>
        {% if item.number %}
          <div class="patent-badge">{{ item.number }}</div>
        {% endif %}
        {% if item.inventors %}
          <div class="cv-detail" style="margin-top: 1rem;">
            <i class="fas fa-user-friends cv-detail-icon"></i>
            <div>
              <div class="cv-detail-label">Inventors:</div>
              <div class="cv-detail-value">{{ item.inventors }}</div>
            </div>
          </div>
        {% endif %}
      </div>
    </div>
  {% endfor %}
</div>

<style>
  .patents {
    margin-bottom: 1.5rem;
  }
  .patent-item {
    margin-bottom: 1.5rem;
    padding-left: 1rem;
    border-left: 3px solid transparent;
  }
  .patent-item:hover {
    border-left-color: #17a2b8;
  }
  .patent-title {
    color: #17a2b8;
    font-weight: 600;
    margin-bottom: 0.25rem;
  }
  .patent-number {
    font-weight: 500;
    color: #495057;
    margin-bottom: 0.25rem;
  }
  .year,
  .inventors {
    color: #6c757d;
    margin-bottom: 0.25rem;
  }
  .year i,
  .inventors i {
    margin-right: 0.5rem;
  }
</style>
