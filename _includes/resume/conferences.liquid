{% assign conferences = data %}
<div class="timeline">
  {% for item in conferences %}
    <div class="timeline-item">
      <div class="timeline-card">
        <div class="timeline-year">{{ item.year }}</div>
        <h4 class="timeline-title">{{ item.role | capitalize }}</h4>
        <div class="timeline-description">{{ item.name }}</div>
      </div>
    </div>
  {% endfor %}
</div>

<style>
  .conferences {
    margin-bottom: 1.5rem;
  }
  .conference-item {
    margin-bottom: 1.5rem;
    padding-left: 1rem;
    border-left: 3px solid transparent;
  }
  .conference-item:hover {
    border-left-color: #28a745;
  }
  .role {
    color: #28a745;
    font-weight: 600;
    margin-bottom: 0.25rem;
  }
  .conference-name {
    font-weight: 500;
    color: #495057;
    margin-bottom: 0.25rem;
  }
  .year {
    color: #6c757d;
  }
  .year i {
    margin-right: 0.5rem;
  }
</style>
