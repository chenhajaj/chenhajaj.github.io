{% assign grants = data %}
<div class="timeline">
  {% for item in grants %}
    <div class="timeline-item">
      <div class="timeline-card">
        <div class="timeline-year">{{ item.period }}</div>
        <h4 class="timeline-title">{{ item.agency }}</h4>
        {% if item.title != '' %}
          <div class="timeline-description">{{ item.title }}</div>
        {% endif %}
        {% if item.investigators %}
          <div class="cv-detail" style="margin-top: 1rem;">
            <i class="fas fa-users cv-detail-icon"></i>
            <div>
              <div class="cv-detail-label">Investigators:</div>
              <div class="cv-detail-value">{{ item.investigators }}</div>
            </div>
          </div>
        {% endif %}
        {% if item.amount %}
          <div class="grant-amount">{{ item.amount }}</div>
        {% endif %}
      </div>
    </div>
  {% endfor %}
</div>

<style>
  .grants {
    margin-bottom: 1.5rem;
  }
  .grant-item {
    margin-bottom: 1.5rem;
    padding-left: 1rem;
    border-left: 3px solid transparent;
    transition: all 0.3s ease;
  }
  .grant-item:hover {
    border-left-color: #2a9d8f;
    background-color: rgba(42, 157, 143, 0.05);
    padding: 1rem;
    border-radius: 0.5rem;
  }
  .grant-agency {
    color: #2a9d8f;
    font-weight: 600;
    margin-bottom: 0.25rem;
  }
  .grant-title {
    font-weight: 500;
    color: #495057;
    margin-bottom: 0.25rem;
  }
  .period,
  .investigators {
    color: #6c757d;
    margin-bottom: 0.25rem;
  }
  .period i,
  .investigators i {
    margin-right: 0.5rem;
    color: #2a9d8f;
  }
</style>
